{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/test.py", "use": "@vercel/python" },
    { "src": "api/txs.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/test", "dest": "/api/test.py" },
    { "src": "/api/txs", "dest": "/api/txs.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
